{
  "routes": [
    {
      "route": "/gallery",
      "rewrite": "/gallery.html"
    },
    {
      "route": "/admin",
      "rewrite": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/artworks",
      "methods": ["POST"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/artworks/*",
      "methods": ["DELETE"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/upload-url",
      "allowedRoles": ["admin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Content-Security-Policy": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: https://*.blob.core.windows.net; connect-src 'self' https://*.blob.core.windows.net; frame-src https://checkout.stripe.com"
  }
}
